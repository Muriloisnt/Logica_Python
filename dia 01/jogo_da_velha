def inicializar_tabuleiro():
    return [[" " for _ in range(3)] for _ in range(3)]


def exibir_tabuleiro(tabuleiro):
    print("\n  0   1   2") 
    for i, linha in enumerate(tabuleiro):
       
        print(f"{i} " + " | ".join(linha))
        if i < 2:
            print("  --" + "+---" * 2)
    print()


def verificar_vitoria(tab, jog):
    
    for linha in tab:
        if all(celula == jog for celula in linha):
            return True

   
    for col in range(3):
        if all(tab[lin][col] == jog for lin in range(3)):
            return True

    
    if all(tab[i][i] == jog for i in range(3)):
        return True
    if all(tab[i][2 - i] == jog for i in range(3)):
        return True

    return False


def tabuleiro_cheio(tabuleiro):
    for linha in tabuleiro:
        if " " in linha:
            return False
    return True


def jogar():
    tabuleiro = inicializar_tabuleiro()
    jogador_atual = "X"

    print("--- JOGO DA VELHA ---")
    exibir_tabuleiro(tabuleiro)

    while True:
        print(f"Turno do jogador: {jogador_atual}")

    
        try:
            linha = int(input("Escolha a linha (0, 1 ou 2): "))
            coluna = int(input("Escolha a coluna (0, 1 ou 2): "))
        except ValueError:
            print("Entrada inválida! Digite apenas números entre 0 e 2.")
            continue

        if not (0 <= linha <= 2 and 0 <= coluna <= 2):
            print("Posição fora do tabuleiro! Escolha valores de 0 a 2.")
            continue

        
        if tabuleiro[linha][coluna] != " ":
            print("Essa posição já está ocupada! Tente outra.")
            continue

        
        tabuleiro[linha][coluna] = jogador_atual
        exibir_tabuleiro(tabuleiro)

        
        if verificar_vitoria(tabuleiro, jogador_atual):
            print(f"Parabéns! O jogador '{jogador_atual}' venceu o jogo!")
            break

        if tabuleiro_cheio(tabuleiro):
            print("Deu empate! O tabuleiro está cheio.")
            break

        
        jogador_atual = "O" if jogador_atual == "X" else "X"



if __name__ == "__main__":
    jogar()
